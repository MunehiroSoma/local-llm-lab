{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SummarizeTagsOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["summary", "tags"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
